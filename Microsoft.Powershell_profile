function whereis($command) {
	Get-Command -Name $command -ErrorAction SilentlyContinue |
	Select-Object -ExpandProperty Path -ErrorAction SilentlyContinue
}
function gpp {
    param(
        [string]$filename,
        [int]$version = 17,
        [string[]]$options = @()
    )

    $outputFilename = $filename -replace '\.cpp$', ''
    $gccCommand = "g++ -std=c++$version -s"
    
    foreach ($option in $options) {
        $gccCommand += " $option"
    }
    
    $gccCommand += " $filename -o $outputFilename"
    Invoke-Expression $gccCommand
}
function ff {
    fzf --preview 'bat --color=always {}'
}

function touch {
    param(
        [string[]]$Paths
    )

    foreach ($Path in $Paths) {
        if (-not (Test-Path $Path)) {
            New-Item -ItemType File -Path $Path | Out-Null
        }
        else {
            (Get-Item $Path).LastWriteTime = Get-Date
        }
    }
}

function time {
    param (
        [Parameter(Mandatory = $true)]
        [ScriptBlock]$Command
    )

    $stopwatch = [Diagnostics.Stopwatch]::StartNew()
    try {
        Invoke-Command -ScriptBlock $Command
    }
    catch{
        Write-Error "Error occured: $_"
    }
    finally {
        $stopwatch.Stop()
        $executionTime = $stopwatch.Elapsed
        Write-Host "Execution time: $executionTime"
    }
}
function notepad++ {
    param (
        [String]$FilePath
    )

    if ($FilePath) {
        Start-Process "C:\Program Files\Notepad++\notepad++.exe" -ArgumentList $FilePath
    } else {
        Start-Process "C:\Program Files\Notepad++\notepad++.exe"
    }
}
function sudo {
    param (
        [String]$Command
    )

    if ($Command) {
        Start-Process powershell -ArgumentList "Start-Process powershell -Verb RunAs -ArgumentList '$Command'"
    } else {
        Start-Process powershell -Verb RunAs
    }
}
function cat {
    param (
        [Parameter(Mandatory=$true)]
        [string]$Path
    )
    bat $Path
}
